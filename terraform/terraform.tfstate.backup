    {
      "mode": "managed",
      "type": "aws_cloudfront_function",
      "name": "index_router",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:cloudfront::503561421839:function/toolithic-index-router",
            "code": "// CloudFront Function — runs on every viewer request (runtime: cloudfront-js-2.0)\n// Next.js static export with trailingSlash:true generates /about/index.html\n// CloudFront's DefaultRootObject only handles the root \"/\", not sub-paths.\n// This function appends index.html to bare directory requests before S3 lookup.\n\nfunction handler(event) {\n    var request = event.request;\n    var uri = request.uri;\n\n    if (uri.endsWith('/')) {\n        // /about/ → /about/index.html\n        request.uri += 'index.html';\n    } else if (!uri.includes('.')) {\n        // /about → /about/index.html  (no file extension = directory route)\n        request.uri += '/index.html';\n    }\n\n    return request;\n}\n",
            "comment": "Rewrite directory requests to index.html for Next.js static export",
            "etag": "ETVPDKIKX0DER",
            "id": "toolithic-index-router",
            "key_value_store_associations": null,
            "live_stage_etag": "ETVPDKIKX0DER",
            "name": "toolithic-index-router",
            "publish": true,
            "runtime": "cloudfront-js-2.0",
            "status": "UNASSOCIATED"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA=="
        }
      ]
    },
